    "Inhibit Response Function", "TA0107", "Service Stop", "T0881", "High",
    "Inhibit Response Function", "TA0107", "System Firmware", "T0857", "Critical",
    // Impair Process Control (TA0106)
    "Impair Process Control", "TA0106", "Brute Force I/O", "T0806", "Critical",
    "Impair Process Control", "TA0106", "Modify Parameter", "T0836", "Critical",
    "Impair Process Control", "TA0106", "Module Firmware", "T0839", "Critical",
    "Impair Process Control", "TA0106", "Spoof Reporting Message", "T0856", "Critical",
    "Impair Process Control", "TA0106", "Unauthorized Command Message", "T0855", "Critical",
    // Impact (TA0105)
    "Impact", "TA0105", "Damage to Property", "T0879", "Critical",
    "Impact", "TA0105", "Denial of Control", "T0813", "Critical",
    "Impact", "TA0105", "Denial of View", "T0815", "Critical",
    "Impact", "TA0105", "Loss of Availability", "T0826", "Critical",
    "Impact", "TA0105", "Loss of Control", "T0827", "Critical",
    "Impact", "TA0105", "Loss of Productivity and Revenue", "T0828", "High",
    "Impact", "TA0105", "Loss of Protection", "T0837", "Critical",
    "Impact", "TA0105", "Loss of Safety", "T0880", "Critical",
    "Impact", "TA0105", "Loss of View", "T0829", "Critical",
    "Impact", "TA0105", "Manipulation of Control", "T0831", "Critical",
    "Impact", "TA0105", "Manipulation of View", "T0832", "Critical",
    "Impact", "TA0105", "Theft of Operational Information", "T0882", "High",
    // Exfiltration (TA0111) — added in ATT&CK for ICS v15+
    "Exfiltration", "TA0111", "Exfiltration Over Alternative Protocol", "T0893", "High"
];

// =================================================================
// SECTION 2: Map active Sentinel analytic rules to techniques
// =================================================================

let DetectionCoverage = SentinelAudit
    | where OperationName == "Analytics rules"
    | where Status == "Active"
    | mv-expand Technique = parse_json(Techniques) to typeof(string)
    | summarize DetectionRules = make_set(RuleName),
        DetectionRuleCount = dcount(RuleName)
        by TechniqueID = Technique;

// =================================================================
// SECTION 3: Define hunting coverage (manual — update after each hunt)
// This section documents which techniques have been actively hunted.
// Update TechniqueID and HuntID after completing each hunt.
// =================================================================

let HuntingCoverage = datatable(
    TechniqueID: string, HuntID: string, LastHunted: datetime
) [
    // Update this table after each hunt execution
    // Format: "TechniqueID", "Hunt-ICS-XXX", datetime(YYYY-MM-DD)
    "T0839", "Hunt-ICS-001", datetime(2026-01-01),  // Firmware modification
    "T0836", "Hunt-ICS-001", datetime(2026-01-01),  // Modify program
    "T0869", "Hunt-ICS-002", datetime(2026-01-01),  // Standard app layer protocol
    "T0802", "Hunt-ICS-002", datetime(2026-01-01),  // Automated collection
    "T0831", "Hunt-ICS-002", datetime(2026-01-01),  // Manipulation of control
    "T0840", "Hunt-ICS-003", datetime(2026-01-01),  // Network connection enum
    "T0846", "Hunt-ICS-003", datetime(2026-01-01),  // Remote system discovery
    "T0842", "Hunt-ICS-003", datetime(2026-01-01),  // Network sniffing
];

let HuntingSummary = HuntingCoverage
    | summarize HuntIDs = make_set(HuntID),
        HuntCount = dcount(HuntID),
        LastHunted = max(LastHunted)
        by TechniqueID;

// =================================================================
// SECTION 4: Combine and produce coverage assessment
// =================================================================

ATTCKforICS_Techniques
| join kind=leftouter DetectionCoverage on TechniqueID
| join kind=leftouter HuntingSummary on TechniqueID
| extend DetectionRuleCount = coalesce(DetectionRuleCount, 0),
    HuntCount = coalesce(HuntCount, 0),
    CoverageStatus = case(
        DetectionRuleCount > 0 and HuntCount > 0, "Full Coverage",
        DetectionRuleCount > 0, "Detection Only",
        HuntCount > 0, "Hunting Only",
        "Gap"
    ),
    HuntStaleness = iff(isnotempty(LastHunted),
        datetime_diff('day', now(), LastHunted),
        int(null)
    )
| project Tactic, TacticID, Technique, TechniqueID, OTPriority,
    CoverageStatus, DetectionRuleCount,
    DetectionRules = coalesce(DetectionRules, dynamic([])),
    HuntCount,
    HuntIDs = coalesce(HuntIDs, dynamic([])),
    LastHunted,
    HuntStaleDays = HuntStaleness,
    // Flag techniques that are high priority AND have gaps
    ActionRequired = iff(
        CoverageStatus == "Gap" and OTPriority in ("Critical", "High"),
        "PRIORITY GAP", ""
    )
| order by TacticID asc, 
    case(OTPriority, "Critical", 0, "High", 1, "Medium", 2, "Low", 3, 4) asc,
    CoverageStatus desc

