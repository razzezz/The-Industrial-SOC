// Chapter_09_ATTCK_ICS_Technique_Coverage.kql
// ================================================================
// MITRE ATT&CK for ICS — Technique-Level Coverage Tracker
// ================================================================
// Description: Extended coverage assessment that maps both detection
//   rules AND hunting operations to ATT&CK for ICS at the technique
//   level (not just tactic). Provides granular gap analysis for
//   prioritising detection engineering and hunting investments.
//
// Usage: Run quarterly. Review results with SOC leadership and
//   detection engineering team. Feed gaps into hunting hypothesis
//   development and detection rule backlog.
//
// Regulatory: Supports NCSC CAF v4.0 C1 (Security Monitoring),
//   C2.b (Threat Hunting), and NIS 2 Art. 21(2)(e) requirements
//   for demonstrating detection and hunting coverage.
//
// Reference: Chapter 9 — The OT Threat Hunting Mindset
// ================================================================

// =================================================================
// SECTION 1: Define the ATT&CK for ICS technique reference table
// This is the authoritative list of techniques we assess against.
// Update when MITRE releases new ATT&CK for ICS versions.
// =================================================================

let ATTCKforICS_Techniques = datatable(
    Tactic: string, TacticID: string,
    Technique: string, TechniqueID: string,
    OTPriority: string
) [
    // Initial Access (TA0108)
    "Initial Access", "TA0108", "Drive-by Compromise", "T0817", "Medium",
    "Initial Access", "TA0108", "Exploit Public-Facing Application", "T0819", "High",
    "Initial Access", "TA0108", "External Remote Services", "T0822", "Critical",
    "Initial Access", "TA0108", "Internet Accessible Device", "T0883", "Critical",
    "Initial Access", "TA0108", "Remote Services", "T0886", "High",
    "Initial Access", "TA0108", "Replication Through Removable Media", "T0847", "High",
    "Initial Access", "TA0108", "Rogue Master", "T0848", "Critical",
    "Initial Access", "TA0108", "Spearphishing Attachment", "T0865", "Medium",
    "Initial Access", "TA0108", "Supply Chain Compromise", "T0862", "High",
    "Initial Access", "TA0108", "Wireless Compromise", "T0860", "Medium",
    "Initial Access", "TA0108", "Transient Cyber Asset", "T0864", "High",
    // Execution (TA0104)
    "Execution", "TA0104", "Change Operating Mode", "T0858", "Critical",
    "Execution", "TA0104", "Command-Line Interface", "T0807", "Medium",
    "Execution", "TA0104", "Execution through API", "T0871", "Medium",
    "Execution", "TA0104", "Modify Controller Tasking", "T0821", "Critical",
    "Execution", "TA0104", "Native API", "T0834", "Medium",
    "Execution", "TA0104", "Scripting", "T0853", "Medium",
    // Persistence (TA0110)
    "Persistence", "TA0110", "Modify Program", "T0889", "Critical",
    "Persistence", "TA0110", "Module Firmware", "T0839", "Critical",
    "Persistence", "TA0110", "Project File Infection", "T0873", "High",
    "Persistence", "TA0110", "System Firmware", "T0857", "Critical",
    "Persistence", "TA0110", "Valid Accounts", "T0859", "High",
    // Evasion (TA0103)
    "Evasion", "TA0103", "Change Operating Mode", "T0858", "High",
    "Evasion", "TA0103", "Exploitation for Evasion", "T0820", "Medium",
    "Evasion", "TA0103", "Indicator Removal on Host", "T0872", "High",
    "Evasion", "TA0103", "Masquerading", "T0849", "Medium",
    "Evasion", "TA0103", "Rootkit", "T0851", "High",
    "Evasion", "TA0103", "Spoof Reporting Message", "T0856", "Critical",
    // Discovery (TA0102)
    "Discovery", "TA0102", "Network Connection Enumeration", "T0840", "High",
    "Discovery", "TA0102", "Network Sniffing", "T0842", "Medium",
    "Discovery", "TA0102", "Remote System Discovery", "T0846", "High",
    "Discovery", "TA0102", "Remote System Information Discovery", "T0888", "Medium",
    // Lateral Movement (TA0109)
    "Lateral Movement", "TA0109", "Default Credentials", "T0812", "Critical",
    "Lateral Movement", "TA0109", "Exploitation of Remote Services", "T0866", "High",
    "Lateral Movement", "TA0109", "Lateral Tool Transfer", "T0867", "High",
    "Lateral Movement", "TA0109", "Program Download", "T0843", "Critical",
    "Lateral Movement", "TA0109", "Remote Services", "T0886", "High",
    "Lateral Movement", "TA0109", "Valid Accounts", "T0859", "High",
    // Collection (TA0100)
    "Collection", "TA0100", "Automated Collection", "T0802", "High",
    "Collection", "TA0100", "Data from Information Repositories", "T0811", "Medium",
    "Collection", "TA0100", "Detect Operating Mode", "T0868", "Medium",
    "Collection", "TA0100", "I/O Image", "T0877", "High",
    "Collection", "TA0100", "Monitor Process State", "T0801", "Medium",
    "Collection", "TA0100", "Point & Tag Identification", "T0861", "High",
    "Collection", "TA0100", "Program Upload", "T0845", "Critical",
    "Collection", "TA0100", "Screen Capture", "T0852", "Low",
    // Command and Control (TA0101)
    "Command and Control", "TA0101", "Commonly Used Port", "T0885", "Medium",
    "Command and Control", "TA0101", "Connection Proxy", "T0884", "Medium",
    "Command and Control", "TA0101", "Standard Application Layer Protocol", "T0869", "High",
    // Inhibit Response Function (TA0107)
    "Inhibit Response Function", "TA0107", "Activate Firmware Update Mode", "T0800", "Critical",
    "Inhibit Response Function", "TA0107", "Alarm Suppression", "T0878", "Critical",
    "Inhibit Response Function", "TA0107", "Block Command Message", "T0803", "Critical",
    "Inhibit Response Function", "TA0107", "Block Reporting Message", "T0804", "Critical",
    "Inhibit Response Function", "TA0107", "Block Serial COM", "T0805", "High",
